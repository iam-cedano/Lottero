PORT=3000

# Your Telegram Bot Token (from BotFather)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIJklmNOPQRstUVwXYz

# The Channel ID (e.g., @mychannel or -100123456789)
TELEGRAM_CHANNEL_ID=@your_channel_username

# Optional: Add a secret key to prevent unauthorized broadcasting
API_SECRET_KEY=my_super_secret_api_key
